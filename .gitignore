# -----------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace
.history/

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Eclipse
.metadata/
*.pydevproject

# Xcode
*.xcworkspace/
*.xcuserdata/

