# =============================================================================
# Adaptive Deep Networks - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django / Flask stuff
*.log
local_settings.py
db.sqlite3

# Scrapy
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# celery
 celerybeat-schedule

# SageMath
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# MkDocs
documentation/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# -----------------------------------------------------------------------------
# Deep Learning / ML
# -----------------------------------------------------------------------------
# Model checkpoints and weights
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.h5
*.pb
*.onnx
*.tflite
*.mlmodel

# Training artifacts
checkpoints/
runs/
wandb/
logs/
lightning_logs/
output/
outputs/
results/
# Note: experiments/ is not ignored - we track the experiment framework code
# Only ignore experiment outputs
experiments/results/

# Datasets (large files)
data/
datasets/
# Allow small Python package for needle dataset (not large data files)
!experiments/real_model/datasets/
!experiments/real_model/datasets/**
raw_data/
processed_data/
*.tfrecord
*.lmdb

# Cache
.cache/
pretrained/
pretrained_models/

# TensorBoard
events.out.tfevents.*

# Weights & Biases
wandb/

# Hugging Face cache
.cache/huggingface/
 transformers_cache/

# -----------------------------------------------------------------------------
# Lambda AI / Cloud
# -----------------------------------------------------------------------------
# SSH keys and credentials
*.pem
*.key
.aws/
.gcp/
.azure/

# Cloud sync artifacts
.sync/
.cloud/

# Temporary files from cloud instances
/tmp/
*.tmp

# -----------------------------------------------------------------------------
