# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.nfs*

# -----------------------------------------------------------------------------
# Project Specific
# -----------------------------------------------------------------------------
# Validation results (generated)
validation_results/
results/
benchmark_results/
ablation_results/

# Large output files
*.json.gz
*.csv.gz
*.pkl.gz
*.tar.gz
*.zip

# Plots and figures (generated)
*.png
*.jpg
*.jpeg
*.pdf
*.svg
!docs/figures/*.png
!docs/figures/*.pdf

# Profiling
*.prof
*.stats
prof/

# Core dumps
core
core.*

# -----------------------------------------------------------------------------
# Keep These Files
# -----------------------------------------------------------------------------
!.gitkeep
!**/.gitkeep
